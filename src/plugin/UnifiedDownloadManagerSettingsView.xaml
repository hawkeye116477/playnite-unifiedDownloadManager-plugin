<UserControl x:Class="UnifiedDownloadManagerNS.UnifiedDownloadManagerSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UnifiedDownloadManagerNS"
             xmlns:common="clr-namespace:CommonPlugin"
             xmlns:system="clr-namespace:System"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <CheckBox Content="{common:Localize Key={x:Static system:LOC.UdmDisplayDownloadTaskFinishedNotifications}}"
                          IsChecked="{Binding Settings.DisplayDownloadTaskFinishedNotifications}" Margin="0,0,0,8" />
            <CheckBox Content="{common:Localize Key={x:Static system:LOC.UdmDisplayDownloadSpeedInBits}}"
                          IsChecked="{Binding Settings.DisplayDownloadSpeedInBits}" Margin="0,0,0,8" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="Left" Width="Auto" />
                    <ColumnDefinition x:Name="Right" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Grid.Column="0" Grid.Row="0"
                            Text="{common:Localize Key={x:Static system:LOC.UdmAfterDownloadComplete}}" Margin="0,0,0,8" VerticalAlignment="Center" HorizontalAlignment="Left"  />
                <ComboBox Grid.Column="1" Grid.Row="0" x:Name="AfterDownloadCompleteCBo" DisplayMemberPath="Value" SelectedValue="{Binding Settings.DoActionAfterDownloadComplete}" SelectedValuePath="Key" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Margin="10,0,0,8" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{common:Localize Key={x:Static system:LOC.UdmAutoRemoveCompletedDownloads}}" Margin="0,0,0,8" VerticalAlignment="Center" HorizontalAlignment="Left"></TextBlock>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="AutoRemoveCompletedDownloadsCBo" DisplayMemberPath="Value" SelectedValue="{Binding Settings.AutoRemoveCompletedDownloads}" SelectedValuePath="Key" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"  Margin="10,0,0,8" HorizontalAlignment="Left" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
