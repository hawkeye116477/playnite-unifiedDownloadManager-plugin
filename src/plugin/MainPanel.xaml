<UserControl x:Class="UnifiedDownloadManagerNS.MainPanel" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:common="clr-namespace:CommonPlugin" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UnifiedDownloadManagerNS" 
             xmlns:localcon="clr-namespace:UnifiedDownloadManagerNS.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:system="clr-namespace:System" 
             d:DesignHeight="450"
             d:DesignWidth="800" Loaded="UserControl_Loaded" PreviewKeyDown="UserControl_PreviewKeyDown" mc:Ignorable="d">

    <UserControl.Resources>
        <sys:Boolean x:Key="True">True</sys:Boolean>
        <sys:Boolean x:Key="False">False</sys:Boolean>
        <FontFamily x:Key="FontIcoFont">/Fonts/icofont.ttf#icofont</FontFamily>
        <localcon:LongToDateConverter x:Key="LongToDateConverter" />
        <localcon:DownloadStatusEnumToStringConverter x:Key="DownloadStatusEnumToStringConverter" />
        <localcon:DurationStringConverter x:Key="DurationConverter" />
        <localcon:SpeedConverter x:Key="SpeedConverter" />
        <localcon:NumericalSizeToStringConverter x:Key="NumericalSizeToStringConverter" />
        <Style BasedOn="{StaticResource HawkeyeSeparatorStyle}" TargetType="Separator" />
        <Style BasedOn="{StaticResource HawkeyeBorderStyle}" TargetType="Border" />
        <Style BasedOn="{StaticResource HawkeyeListBoxStyle}" TargetType="ListBox" />
        <Style BasedOn="{StaticResource HawkeyeTextBlockStyle}" TargetType="TextBlock" />
        <Style BasedOn="{StaticResource HawkeyeButtonStyle}" TargetType="Button" />
        <Style BasedOn="{StaticResource HawkeyeExpanderStyle}" TargetType="Expander" />
        <Style BasedOn="{StaticResource HawkeyeTabControlStyle}" TargetType="TabControl" />
        <Style BasedOn="{StaticResource HawkeyeDataGridStyle}" TargetType="DataGrid" />
        <Style BasedOn="{StaticResource HawkeyeDataGridCellStyle}" TargetType="DataGridCell" />
        <Style BasedOn="{StaticResource HawkeyeDataGridRowStyle}" TargetType="DataGridRow" />
        <Style BasedOn="{StaticResource HawkeyeDataGridColumnHeaderStyle}" TargetType="DataGridColumnHeader" />
    </UserControl.Resources>
    <Grid Margin="10,10,10,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Grid.Row="0" VerticalAlignment="Top" Orientation="Vertical">
                <StackPanel Margin="0,0,0,10" DockPanel.Dock="Top" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Style="{x:Null}" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Hyperlink Name="BackHl" Click="BackHl_Click">
                            <TextBlock FontFamily="{DynamicResource FontIcoFont}" FontSize="26" Style="{x:Null}" Text="&#xea5c;" />
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="18" Text="{common:Localize Key={x:Static system:LOC.UdmDownloadManager}}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal">
                    <Button
                        x:Name="ResumeDownloadBtn" Click="ResumeDownloadBtn_Click" Content="&#xec74;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="{Binding CanResume}"
                        ToolTip="{common:Localize Key={x:Static system:LOC.UdmResumeDownload}}" />
                    <Button
                        x:Name="PauseBtn" Margin="5,0,0,0" Click="PauseBtn_Click" Content="&#xec72;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="{Binding CanPause}"
                        ToolTip="{common:Localize Key={x:Static system:LOC.UdmPauseDownload}}" />
                    <Button
                        x:Name="CancelDownloadBtn" Margin="5,0,0,0" Click="CancelDownloadBtn_Click" Content="&#xec73;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="{Binding CanCancel}"
                        ToolTip="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteCancelLabel}}" />
                    <Separator Margin="10,0,5,0" />
                    <Button
                        Name="MoveTopBtn" Margin="5,0,0,0" Click="MoveTopBtn_Click" Content="&#xea95;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="False" />
                    <Button
                        Name="MoveUpBtn" Margin="5,0,0,0" Click="MoveUpBtn_Click" Content="&#xea5e;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="False" />
                    <Button
                        Name="MoveDownBtn" Margin="5,0,0,0" Click="MoveDownBtn_Click" Content="&#xea5b;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="False" />
                    <Button
                        Name="MoveBottomBtn" Margin="5,0,0,0" Click="MoveBottomBtn_Click" Content="&#xea92;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="False" />
                    <Separator Margin="10,0,5,0" />
                    <Button
                        x:Name="SelectAllBtn" Margin="5,0,0,0" Click="SelectAllBtn_Click" Content="&#xeed9;"
                        FontFamily="{DynamicResource FontIcoFont}" />
                    <Button
                        x:Name="RemoveDownloadBtn" Margin="5,0,0,0" Click="RemoveDownloadBtn_Click" Content="&#xec53;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="False" />
                    <Button
                        x:Name="RemoveCompletedDownloadsBtn" Margin="5,0,0,0" Click="RemoveCompletedDownloadsBtn_Click" Content="&#xef9f;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        ToolTip="{common:Localize Key={x:Static system:LOC.UdmRemoveCompletedDownloads}}" />
                    <Separator Margin="10,0,5,0" />
                    <Button
                        x:Name="DownloadPropertiesBtn" Margin="5,0,0,0" Click="DownloadPropertiesBtn_Click" Content="&#xefe2;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="False" />
                    <Button
                        x:Name="OpenDownloadDirectoryBtn" Margin="5,0,0,0" Click="OpenDownloadDirectoryBtn_Click" Content="&#xef35;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="False" />
                    <Button
                        x:Name="FilterDownloadBtn" Margin="5,0,0,0" Click="FilterDownloadBtn_Click" Content="&#xef29;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        ToolTip="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteFilters}}" />
                    <Separator Margin="10,0,5,0" />
                    <Button
                        x:Name="OpenPluginSettingsBtn" Margin="5,0,0,0" Click="OpenPluginSettingsBtn_Click" Content="&#xefb0;"
                        FontFamily="{DynamicResource FontIcoFont}"
                        IsEnabled="True"
                        ToolTip="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteSettingsLabel}}" />
                </StackPanel>
                <Separator Margin="0,5,0,5" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftCol" Width="4*" />
                <ColumnDefinition x:Name="MiddleCol" Width="Auto" />
                <ColumnDefinition x:Name="RightCol" Width="1*" />
            </Grid.ColumnDefinitions>
            <DataGrid
                    x:Name="DownloadsDG" Margin="0,0,0,10" HorizontalAlignment="Left" VerticalAlignment="Top"
                    AutoGenerateColumns="False" CanUserResizeColumns="True" CanUserSortColumns="True" ColumnWidth="*"
                    EnableColumnVirtualization="True" EnableRowVirtualization="True" HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding Downloads}"
                    ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionChanged="DownloadsDG_SelectionChanged"
                    VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Standard" Grid.Row="0" Grid.Column="0" >
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding name}" Header="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteGameNameTitle}}" />
                    <DataGridTextColumn Binding="{Binding sourceName}" Header="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteSourceLabel}}" />
                    <DataGridTemplateColumn Header="{common:Localize Key={x:Static system:LOC.UdmProgress}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ProgressBar Name="DownloadPB" Value="{Binding progress}" />
                                    <TextBlock
                                            Margin="0,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Style="{DynamicResource HawkeyeTextBlockStyle}"
                                            Text="{Binding progress, StringFormat={}{0:0}%}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{common:Localize Key={x:Static system:LOC.UdmDownloaded}}">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Converter="{StaticResource NumericalSizeToStringConverter}" Path="downloadedBytes" />
                                <Binding Converter="{StaticResource NumericalSizeToStringConverter}" Path="downloadSizeBytes" />
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding installSizeBytes, Converter={StaticResource NumericalSizeToStringConverter}}" Header="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteInstallSizeLabel}}" />
                    <DataGridTextColumn Binding="{Binding status, Converter={StaticResource DownloadStatusEnumToStringConverter}}" Header="{common:Localize Key={x:Static system:LOC.UdmDownloadStatus}}" />
                    <DataGridTextColumn Binding="{Binding addedTime, Converter={StaticResource LongToDateConverter}}" Header="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteAddedLabel}}" />
                    <DataGridTextColumn Binding="{Binding completedTime, Converter={StaticResource LongToDateConverter}}" Header="{common:Localize Key={x:Static system:LOC.UdmDownloadCompletedColumn}}" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Name="FiltersSepSP" Grid.Column="1" Margin="10,0,0,0" Orientation="Horizontal">
                <Separator />
            </StackPanel>
            <StackPanel Name="FilterSP" Grid.Column="2" Margin="10,0,0,0" DockPanel.Dock="Right">
                <Button Content="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteClearFilters}}" Margin="0,0,0,10" Click="ClearFiltersBtn_Click" IsEnabled="False" Name="ClearFiltersBtn"></Button>
                <TextBlock Margin="0,0,0,5" Text="{common:Localize Key={x:Static system:LOC.UdmDownloadStatus}}" />
                <Grid Margin="0,0,0,7">
                    <ComboBox x:Name="StatusCBo" HorizontalContentAlignment="Stretch" IsEditable="False" SelectionChanged="StatusCBo_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Checked="StatusChk_Changed" Content="{Binding Converter={StaticResource DownloadStatusEnumToStringConverter}}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Unchecked="StatusChk_Changed" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock
                            Name="StatusTb" Margin="5,0,20,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                            Panel.ZIndex="1" ClipToBounds="True" IsHitTestVisible="False" TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                </Grid>
                <TextBlock Margin="0,0,0,5" Text="{common:Localize Key={x:Static system:LOC.ThirdPartyPlayniteSourceLabel}}" />
                <Grid Margin="0,0,0,7">
                    <ComboBox
                            x:Name="SourceCBo" HorizontalContentAlignment="Stretch" DropDownOpened="SourceCBo_DropDownOpened" IsEditable="False"
                            ItemsSource="{Binding AllSources}"
                            SelectionChanged="StatusCBo_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox
                                        x:Name="SourceChk" Checked="SourceChk_Changed"
                                        Content="{Binding Converter={StaticResource DownloadStatusEnumToStringConverter}}"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                        Unchecked="SourceChk_Changed" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock
                            Name="SourceTb" Margin="5,0,20,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                            Panel.ZIndex="1" ClipToBounds="True" IsHitTestVisible="False" TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                </Grid>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Separator Grid.Row="0" Grid.ColumnSpan="2" Margin="0,5,0,10" />
            <TextBlock
                Name="GameTitleTB" Grid.Row="1" Grid.Column="0" Margin="0,0,0,5"
                HorizontalAlignment="Left"
                Text="{Binding ActiveTask.name, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
                x:Name="DescriptionTB" Grid.Row="2" Margin="0,0,0,5" HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Text="{Binding ActiveTask.activity, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel
                Grid.Row="4" Grid.Column="0" Margin="0,0,0,5" HorizontalAlignment="Left"
                VerticalAlignment="Top" Orientation="Horizontal">
                <TextBlock Text="{common:Localize Key={x:Static system:LOC.UdmDownloadSpeed}}" />
                <TextBlock Name="DownloadSpeedTB" Margin="5,0,30,0" HorizontalAlignment="Left" Text="{Binding ActiveTask.downloadSpeedBytes, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SpeedConverter}}" />
            </StackPanel>
            <StackPanel
                Grid.Row="4" Grid.Column="1" Margin="0,0,0,5" HorizontalAlignment="Left"
                VerticalAlignment="Top" Orientation="Horizontal">
                <TextBlock Text="{common:Localize Key={x:Static system:LOC.UdmElapsed}}" />
                <TextBlock Name="ElapsedTB" Margin="5,0,0,0" HorizontalAlignment="Left" Text="{Binding ActiveTask.elapsed, Converter={StaticResource DurationConverter}, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel
                Grid.Row="5" Grid.Column="0" Margin="0,0,0,5" HorizontalAlignment="Left"
                VerticalAlignment="Top" Orientation="Horizontal">
                <TextBlock Text="{common:Localize Key={x:Static system:LOC.UdmDiskSpeed}}" />
                <TextBlock Name="DiskSpeedTB" Margin="5,0,30,0" HorizontalAlignment="Left" Text="{Binding ActiveTask.diskWriteSpeedBytes, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SpeedConverter}}" />
            </StackPanel>
            <StackPanel
                Grid.Row="5" Grid.Column="1" Margin="0,0,0,5" HorizontalAlignment="Left"
                VerticalAlignment="Top" Orientation="Horizontal">
                <TextBlock Text="{common:Localize Key={x:Static system:LOC.UdmEta}}" />
                <TextBlock Name="EtaTB" Margin="5,0,0,0" HorizontalAlignment="Left" Text="{Binding ActiveTask.eta, Converter={StaticResource DurationConverter}, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

    </Grid>

</UserControl>
